# Lyric Studio Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Data directory (default: ./data)
# Set to an absolute path to store user data outside the repo
# LYRIC_STUDIO_DATA=/path/to/my/lyric-studio-data

# WhisperX settings (optional)
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
